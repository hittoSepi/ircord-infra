# Generated deployments write the live config to `turn/turnserver.conf`.
# Copy this file only for manual/local testing.

fingerprint
use-auth-secret=no
lt-cred-mech

realm=turn.example.com
user=ircord:replace-with-your-turn-password

listening-ip=0.0.0.0
external-ip=203.0.113.10
listening-port=3478
tls-listening-port=5349
min-port=49160
max-port=49200

cert=/etc/coturn/certs/turn.example.com.crt
pkey=/etc/coturn/certs/turn.example.com.key

no-cli
no-multicast-peers
no-tlsv1
no-tlsv1_1
