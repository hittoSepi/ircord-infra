# Host nginx example when Docker should not own ports 80/443.
#
# Docker containers stay on localhost:
# - landing   -> 127.0.0.1:8080
# - directory -> 127.0.0.1:3000
#
# This example shows separate landing + directory domains:
# - chat.example.com       -> landing page
# - directory.example.com  -> directory API
#
# For same-domain deployment, proxy /api/ on chat.example.com instead and
# set IRCORD_CONFIG.DIRECTORY_URL to https://chat.example.com.

server {
    listen 80;
    server_name chat.example.com;
    return 301 https://$host$request_uri;
}

server {
    listen 80;
    server_name directory.example.com;
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl http2;
    server_name directory.example.com;

    ssl_certificate /etc/letsencrypt/live/directory.example.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/directory.example.com/privkey.pem;

    location /api/ {
        proxy_pass http://127.0.0.1:3000/api/;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        add_header Access-Control-Allow-Origin $http_origin always;
        add_header Access-Control-Allow-Methods "GET, POST, OPTIONS" always;
        add_header Access-Control-Allow-Headers "Content-Type" always;
        add_header Vary "Origin" always;

        if ($request_method = OPTIONS) {
            return 204;
        }
    }

    location = /api/health {
        proxy_pass http://127.0.0.1:3000/api/health;
        access_log off;
        add_header Access-Control-Allow-Origin $http_origin always;
        add_header Vary "Origin" always;
    }
}

server {
    listen 443 ssl http2;
    server_name chat.example.com;

    ssl_certificate /etc/letsencrypt/live/chat.example.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/chat.example.com/privkey.pem;

    location /api/ {
        proxy_pass http://127.0.0.1:3000/api/;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        add_header Access-Control-Allow-Origin $http_origin always;
        add_header Access-Control-Allow-Methods "GET, POST, OPTIONS" always;
        add_header Access-Control-Allow-Headers "Content-Type" always;
        add_header Vary "Origin" always;

        if ($request_method = OPTIONS) {
            return 204;
        }
    }

    location / {
        proxy_pass http://127.0.0.1:8080;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }
}
